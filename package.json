    "ethers": "^6.17.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "secrets.js-34r7h": "^2.0.2",
    "w3pk": "^0.10.2"
